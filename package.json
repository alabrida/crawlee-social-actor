{
  "name": "crawlee-social-scraper",
  "version": "0.1.0",
  "type": "module",
  "description": "Unified Apify Actor for scraping 8+ social media and business-listing platforms using a hybrid Crawlee architecture.",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/main.js",
  "scripts": {
    "start": "node --env-file=.env dist/main.js",
    "dev": "npx tsx --env-file=.env src/main.ts",
    "build": "tsc",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate-output": "tsx scripts/validate-output.ts",
    "measure-cu": "tsx scripts/measure-cu.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.48.1",
    "apify": "3.2.6",
    "cheerio": "1.2.0",
    "crawlee": "3.16.0",
    "playwright": "1.50.1"
  },
  "devDependencies": {
    "@types/node": "22.12.0",
    "eslint": "9.19.0",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "3.0.5"
  },
  "author": "",
  "license": "ISC"
}
