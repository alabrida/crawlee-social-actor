{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Actor Input",
  "description": "Input schema for the Social Media & Business Listing Scraper actor.",
  "type": "object",
  "required": ["urls"],
  "properties": {
    "platforms": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["tiktok", "youtube", "linkedin", "google_maps", "pinterest", "reddit", "facebook", "instagram", "general"]
      },
      "default": ["tiktok", "youtube"]
    },
    "urls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["platform", "url"],
        "properties": {
          "platform": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        }
      }
    },
    "proxy": {
      "type": "object",
      "properties": {
        "useApifyProxy": { "type": "boolean", "default": true },
        "apifyProxyGroups": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["RESIDENTIAL"]
        },
        "proxyUrls": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Third-party proxy URLs (used when useApifyProxy is false)"
        }
      }
    },
    "maxConcurrency": { "type": "integer", "default": 5, "minimum": 1, "maximum": 20 },
    "maxRequestRetries": { "type": "integer", "default": 3, "minimum": 0, "maximum": 10 },
    "linkedinDailyLimit": { "type": "integer", "default": 250, "maximum": 250 },
    "googleMapsGrid": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "cellSizeKm": { "type": "number", "default": 5, "minimum": 1 }
      }
    }
  }
}
