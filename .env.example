# Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Supabase (Blocker Registry) ---
# Project: Crawlee Social Scraper (wraqaqyqqeswufbarhcz)
# Region: us-east-1
SUPABASE_URL=https://wraqaqyqqeswufbarhcz.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# --- Apify ---
# Required for: apify call, Actor.createProxyConfiguration(), cloud deploys
APIFY_TOKEN=your-apify-api-token-here

# --- Third-Party Proxies (Optional) ---
# Used during local RED/GREEN iteration when not using Apify Cloud
# Comma-separated list of proxy URLs
# PROXY_URLS=http://user:pass@proxy1:8080,http://user:pass@proxy2:8080
